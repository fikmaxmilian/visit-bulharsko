---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import data from '../../data/site-data.json';

export function getStaticPaths() {
  return [...data.posts, ...data.pages]
    .filter((p) => p.path !== '/')
    .map((p) => ({ params: { slug: p.slug }, props: { item: p } }));
}
const { item } = Astro.props;
const related = data.posts.filter((p: any) => p.slug !== item.slug && p.categories?.some((c: any) => item.categories?.some((ic: any) => ic.slug === c.slug))).slice(0,3);
const title = item.seo?.title || item.title;
const description = item.seo?.description || item.excerpt || 'Visit Bulharsko';
const date = item.date ? new Date(item.date).toLocaleDateString('cs-CZ', { day: 'numeric', month: 'long', year: 'numeric' }) : '';
---
<BaseLayout title={title} description={description} image={item.featured_image || undefined} canonical={item.path}>
  <article class="mx-auto max-w-4xl px-5 pt-12">
    <div class="text-center">
      {item.categories?.[0] && <a href={`/category/${item.categories[0].slug}/`} class="meta-chip">{item.categories[0].name}</a>}
      <h1 class="mt-5 font-display text-4xl font-black leading-tight md:text-6xl">{item.title}</h1>
      {item.type === 'post' && <p class="mt-4 text-sm font-semibold uppercase tracking-wide text-plum/60">Luke Palm · {date} · {item.reading_minutes} min čtení</p>}
      {item.excerpt && <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-plum/75">{item.excerpt}</p>}
    </div>
    {item.featured_image && <img src={item.featured_image} alt={item.featured_alt || item.title} class="mt-10 max-h-[560px] w-full rounded-[2rem] object-cover shadow-soft" />}
    <div class="my-10"><AdSlot label="ADS / reklamní prostor v článku" /></div>
    <div class="article-content" set:html={item.content}></div>
  </article>
  {item.type === 'post' && (
    <section class="section-wrap"><div class="section-head"><h2>Související články</h2><a href="/">Zpět na magazín →</a></div><div class="grid gap-8 md:grid-cols-3">{related.map((p) => <PostCard post={p} />)}</div></section>
  )}
</BaseLayout>
